{
  "name": "rooms-upon-rooms",
  "version": "0.1.0",
  "description": "A text-based world simulation",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"tsx watch --exclude data --exclude userdata --env-file=.env src/server/index.ts\" \"vite\"",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "lint:oxlint": "oxlint -A no-unused-vars",
    "lint:knip": "knip",
    "lint:circular": "madge --circular --extensions ts,tsx src/",
    "prepare": "husky",
    "test": "tap",
    "bundle-games": "tsx scripts/bundle-game-data.ts",
    "pull-data": "tsx scripts/pull-d1-data.ts",
    "deploy": "npm run bundle-games && wrangler deploy",
    "deploy:preview": "npm run bundle-games && wrangler dev",
    "bugs": "tsx --env-file=.env scripts/bugs.ts",
    "errors": "tsx scripts/errors.ts",
    "agent": "tsx scripts/agent.ts",
    "eval": "tsx --env-file=.env scripts/agent-eval.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ianb/roomsuponrooms.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/ianb/roomsuponrooms/issues"
  },
  "homepage": "https://github.com/ianb/roomsuponrooms#readme",
  "devDependencies": {
    "@ianbicking/personal-vibe-check": "file:../personal-vibe-check",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "agent-doctest": "file:../callback/agent-doctest",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "knip": "^6.0.4",
    "lint-staged": "^16.4.0",
    "madge": "^8.0.0",
    "oxlint": "^1.56.0",
    "prettier": "^3.8.1",
    "tap": "^21.6.2",
    "tsx": "^4.21.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint"
    ]
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/google": "^3.0.53",
    "@ai-sdk/provider": "^3.0.10",
    "@cfworker/json-schema": "^4.1.1",
    "@google/generative-ai": "^0.24.1",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-router": "^1.168.3",
    "@trpc/client": "^11.15.0",
    "@trpc/server": "^11.15.0",
    "@vitejs/plugin-react": "^6.0.1",
    "acorn": "^8.16.0",
    "ai": "^6.0.138",
    "fastify": "^5.8.4",
    "jq-wasm": "^1.1.0-jq-1.8.1",
    "nanoid": "^5.1.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-textarea-autosize": "^8.5.9",
    "sval": "^0.6.9",
    "vite": "^8.0.2",
    "zod": "^4.3.6"
  },
  "overrides": {
    "ink": "^6.8.0"
  }
}
