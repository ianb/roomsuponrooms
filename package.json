{
  "name": "extensoworld",
  "version": "0.1.0",
  "description": "A text-based world simulation",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"tsx watch src/server/index.ts\" \"vite\"",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "lint:oxlint": "oxlint -A no-unused-vars",
    "lint:knip": "knip",
    "lint:circular": "madge --circular --extensions ts,tsx src/",
    "prepare": "husky",
    "test": "tap"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ianb/extensoworld.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/ianb/extensoworld/issues"
  },
  "homepage": "https://github.com/ianb/extensoworld#readme",
  "devDependencies": {
    "@ianbicking/personal-vibe-check": "file:../personal-vibe-check",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "agent-doctest": "file:../callback/agent-doctest",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "knip": "^6.0.4",
    "lint-staged": "^16.4.0",
    "madge": "^8.0.0",
    "oxlint": "^1.56.0",
    "prettier": "^3.8.1",
    "tap": "^21.6.2",
    "tsx": "^4.21.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint"
    ]
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-router": "^1.168.3",
    "@trpc/client": "^11.15.0",
    "@trpc/server": "^11.15.0",
    "@vitejs/plugin-react": "^6.0.1",
    "fastify": "^5.8.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vite": "^8.0.2",
    "zod": "^4.3.6"
  },
  "overrides": {
    "ink": "^6.8.0"
  }
}
